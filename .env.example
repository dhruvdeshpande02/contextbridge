# ── Database ───────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://contextbridge:CHANGE_ME@db:5432/contextbridge
POSTGRES_USER=contextbridge
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=contextbridge

# ── Redis / Celery ─────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── Rate limiting ──────────────────────────────────────────────────────────────
# Backed by the same Redis instance. Disable only for local scripting/debugging.
RATE_LIMIT_ENABLED=true

# ── Auth ───────────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CHANGE_ME_TO_RANDOM_64_CHAR_HEX
ACCESS_TOKEN_EXPIRE_MINUTES=60
ALGORITHM=HS256

# ── OpenAI ─────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_EXTRACTION_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# ── Frontend ───────────────────────────────────────────────────────────────────
# Set to your EC2 public IP or domain. Used at Next.js build time.
# With Nginx:  https://yourdomain.com/api
# Without:     http://YOUR_EC2_IP:8000
NEXT_PUBLIC_API_URL=http://YOUR_EC2_IP_OR_DOMAIN/api
