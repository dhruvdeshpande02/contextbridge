# Copy this to .env on the EC2 instance and fill in real values.
# These two sections must stay in sync: POSTGRES_* builds the db container,
# DATABASE_URL is what the app uses to connect to it.

POSTGRES_USER=contextbridge
POSTGRES_PASSWORD=change-me-to-a-long-random-password
POSTGRES_DB=contextbridge
DATABASE_URL=postgresql://contextbridge:change-me-to-a-long-random-password@db:5432/contextbridge

REDIS_URL=redis://redis:6379/0

SECRET_KEY=generate-with-python-secrets-token-hex-32
ACCESS_TOKEN_EXPIRE_MINUTES=60
ALGORITHM=HS256

OPENAI_API_KEY=sk-your-real-key-here
OPENAI_EXTRACTION_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

RATE_LIMIT_ENABLED=true

# Used at Next.js build time (Docker build arg) — with Nginx this is your
# domain behind /api; without it, http://YOUR_EC2_IP:8000 directly.
NEXT_PUBLIC_API_URL=https://yourdomain.com/api

# Comma-separated origins the API accepts browser requests from.
CORS_ORIGINS=https://yourdomain.com
